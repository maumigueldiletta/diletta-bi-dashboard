# Diletta BI · environment variables

# Required: secret used to sign magic link tokens and session cookies.
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=

# Required in prod: public URL where the app is served (sem trailing slash)
NEXTAUTH_URL=https://dashboard.dilettasolutions.com

# Allowlist: emails específicos OU domínios inteiros que podem logar
ALLOWED_EMAILS=m.miguel@dilettasolutions.com,maumiguel82@gmail.com
ALLOWED_DOMAINS=dilettasolutions.com

# Resend API key (https://resend.com/api-keys)
RESEND_API_KEY=
# Sender (precisa ser de um domínio verificado no Resend)
RESEND_FROM="Diletta BI <notify@dilettasolutions.io>"

# Feature flag para bypass auth em demos (defina =1 só em emergência)
# DISABLE_AUTH=1
